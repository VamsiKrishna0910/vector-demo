# Milvus Configuration
MILVUS_URI=tcp://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=pdf_docs
MORTGAGE_MILVUS_COLLECTION=mortgage_docs
MORTGAGE_MATCH_SCORE_MIN=0.35

# Embedding Model (default: sentence-transformers/all-MiniLM-L6-v2)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking Policy
CHUNK_SIZE_CHARS=1200
CHUNK_OVERLAP_CHARS=200

# Search Policy
TOP_K=5

# PDF Ingestion Filter (default: *.pdf)
# PDF_GLOB=*.pdf

# LLM Configuration
# Option 1: Use Ollama (default)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama2

# Option 2: Uncomment to use OpenAI instead
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# API Server
API_HOST=0.0.0.0
API_PORT=8000
